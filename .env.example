# =============================================================================
# AEGIS AI — example environment (no real secrets; safe to commit)
# =============================================================================
# Copy to `.env` in the repository root or `backend/.env`
# Never commit real `.env` files to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8787
FRONTEND_URL=http://localhost:5173

JWT_SECRET=

# -----------------------------------------------------------------------------
# OLLAMA (LOCAL AI)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# OLLAMA_DISABLED=

# -----------------------------------------------------------------------------
# CLOUDFLARE WORKERS AI
# -----------------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_API_TOKEN=
# CF_WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# -----------------------------------------------------------------------------
# CEREBRAS
# -----------------------------------------------------------------------------
CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# -----------------------------------------------------------------------------
# OPENROUTER
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# -----------------------------------------------------------------------------
# GROQ
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# HUGGINGFACE
# -----------------------------------------------------------------------------
HF_API_KEY=
HF_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
HF_VISION_MODEL=Salesforce/blip-image-captioning-large

# -----------------------------------------------------------------------------
# GEMINI VISION
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_VISION_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# SMS
# -----------------------------------------------------------------------------
TEXTBELT_API_KEY=textbelt

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMS_COOLDOWN_MS=300000

# -----------------------------------------------------------------------------
# FILES
# -----------------------------------------------------------------------------
# UPLOAD_MAX_BYTES=8388608

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=AEGIS AI <noreply@aegis.local>

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# OPENSTREETMAP
# -----------------------------------------------------------------------------
OSM_USER_AGENT=AEGIS-AI-Healthcare-OS/1.0

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
VITE_API_URL=

# -----------------------------------------------------------------------------
# PUBLIC BACKEND URL
# -----------------------------------------------------------------------------
# API_PUBLIC_BASE_URL=http://localhost:8787
