  "firstAid.steps.st1": "ರೋಗಲಕ್ಷಣಗಳು ಯಾವಾಗ ಪ್ರಾರಂಭವಾದವು ಎಂಬುದನ್ನು ಗಮನಿಸಿ",
  "firstAid.steps.st2": "ವಾಯುಮಾರ್ಗವನ್ನು ಸ್ಪಷ್ಟವಾಗಿ ಇರಿಸಿ;",
  "firstAid.steps.st3": "ಸಹಾಯ ಬರುವವರೆಗೂ ಅವರೊಂದಿಗೆ ಇರಿ",
  "firstAid.steps.bu0": "ಹರಿಯುವ ನೀರಿನಿಂದ 20 ನಿಮಿಷಗಳವರೆಗೆ ತಣ್ಣಗಾಗಿಸಿ",
  "firstAid.steps.bu1": "ಬರ್ನ್ ಬಳಿ ಬಿಗಿಯಾದ ವಸ್ತುಗಳನ್ನು ತೆಗೆದುಹಾಕಿ",
  "firstAid.steps.bu2": "ಸ್ವಚ್ಛವಾದ ಬಟ್ಟೆಯಿಂದ ಸಡಿಲವಾಗಿ ಮುಚ್ಚಿ",
  "firstAid.steps.bu3": "ದೊಡ್ಡ ಅಥವಾ ಆಳವಾದ ಸುಟ್ಟಗಾಯಗಳಿಗೆ ಕಾಳಜಿಯನ್ನು ಪಡೆಯಿರಿ",
  "firstAid.steps.bl0": "ದೃಢವಾದ ನೇರ ಒತ್ತಡವನ್ನು ಅನ್ವಯಿಸಿ",
  "firstAid.steps.bl1": "ಯಾವುದೇ ಮುರಿತದ ಅನುಮಾನವಿದ್ದಲ್ಲಿ ಅಂಗವನ್ನು ಮೇಲಕ್ಕೆತ್ತಿ",
  "firstAid.steps.bl2": "ರಕ್ತವು ನೆನೆಸಿದರೆ ಪದರಗಳನ್ನು ಸೇರಿಸಿ - ಮೊದಲ ಪ್ಯಾಡ್ ಅನ್ನು ತೆಗೆದುಹಾಕಬೇಡಿ",
  "firstAid.steps.bl3": "ತೀವ್ರ ರಕ್ತಸ್ರಾವಕ್ಕಾಗಿ ತುರ್ತು ಸೇವೆಗಳಿಗೆ ಕರೆ ಮಾಡಿ",
  "firstAid.steps.sz0": "ಗಾಯದಿಂದ ರಕ್ಷಿಸಿ - ಕುಶನ್ ತಲೆ, ಸ್ಪಷ್ಟ ಅಪಾಯಗಳು",
  "firstAid.steps.sz1": "ಸೆಳವು ಸಮಯ;",
  "firstAid.steps.sz2": "ನಿಗ್ರಹಿಸಬೇಡಿ ಅಥವಾ ಬಾಯಿಯಲ್ಲಿ ಏನನ್ನೂ ಹಾಕಬೇಡಿ",
  "firstAid.steps.sz3": "> 5 ನಿಮಿಷಗಳು ಅಥವಾ ಪುನರಾವರ್ತನೆಗಳಾದರೆ ತುರ್ತು ಸೇವೆಗಳಿಗೆ ಕರೆ ಮಾಡಿ",
  "firstAid.steps.br0": "ನೇರವಾಗಿ ಕುಳಿತುಕೊಳ್ಳಿ, ಬಿಗಿಯಾದ ಬಟ್ಟೆಗಳನ್ನು ಸಡಿಲಗೊಳಿಸಿ, ಶಾಂತವಾಗಿರಿ",
  "firstAid.steps.br1": "ಲಭ್ಯವಿದ್ದರೆ ವೈಯಕ್ತಿಕ ಆಸ್ತಮಾ ಯೋಜನೆಯನ್ನು ಅನುಸರಿಸಿ",
  "firstAid.steps.br2": "ತೀವ್ರ ತೊಂದರೆ ಅಥವಾ ನೀಲಿ ತುಟಿಗಳಿಗೆ ತುರ್ತು ಸೇವೆಗಳಿಗೆ ಕರೆ ಮಾಡಿ",
  "firstAid.steps.br3": "ಸಹಾಯ ಬರುವವರೆಗೆ ಮೇಲ್ವಿಚಾರಣೆ ಮಾಡಿ",
  "firstAid.steps.fv0": "ದ್ರವ ಮತ್ತು ವಿಶ್ರಾಂತಿಯನ್ನು ಉತ್ತೇಜಿಸಿ",
  "firstAid.steps.fv1": "ಪ್ರತಿ ಲೇಬಲ್ ಅಥವಾ ವೈದ್ಯರ ಸಲಹೆಗೆ ಮಾತ್ರ ಜ್ವರನಿವಾರಕಗಳನ್ನು ಬಳಸಿ",
  "firstAid.steps.fv2": "ಕೆಂಪು ಧ್ವಜದ ರೋಗಲಕ್ಷಣಗಳಿಗೆ ತುರ್ತು ಆರೈಕೆಯನ್ನು ಪಡೆಯಿರಿ",
  "firstAid.steps.ch0": "ಪರಿಣಾಮಕಾರಿ ಕೆಮ್ಮುವಿಕೆಯನ್ನು ಉತ್ತೇಜಿಸಿ",
  "firstAid.steps.ch1": "ಭುಜದ ಬ್ಲೇಡ್‌ಗಳ ನಡುವೆ 5 ದೃಢವಾದ ಬೆನ್ನಿನ ಹೊಡೆತಗಳನ್ನು ನೀಡಿ",
  "firstAid.steps.ch2": "ನಂತರ ತರಬೇತಿ ಪಡೆದರೆ 5 ಕಿಬ್ಬೊಟ್ಟೆಯ ಒತ್ತಡಗಳು (ವಯಸ್ಕರು)",
  "firstAid.steps.ch3": "ಅಡಚಣೆ ಮುಂದುವರಿದರೆ ತುರ್ತು ಸೇವೆಗಳಿಗೆ ಕರೆ ಮಾಡಿ",
